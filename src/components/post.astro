---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props as Props;

const publishedAt = post.data.publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${post.id}`}
  class:list={["post-card", { "post-card-featured": featured }]}
>
  {
    post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.title}
        class="post-card-image"
        loading="lazy"
      />
    )
  }

  <article class="post-card-body">
    <p class="post-card-date">{publishedAt}</p>
    <h2 class="post-card-title">{post.data.title}</h2>
    <p class="post-card-description">{post.data.description}</p>
    <span class="post-card-link">Read article</span>
  </article>
</a>
