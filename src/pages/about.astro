---
import { Image } from "astro:assets";
import { default as Layout } from "../layouts/BaseLayout.astro";
import Heading from "../components/heading.astro";
import Job from "../components/job.astro";
import { jobs } from "../data/jobs";
import portraitImage from "../assets/me.jpg";
---

<Layout title="About">
  <section class="page-intro">
    <p class="eyebrow">About</p>
    <Heading>Steffen Beisenherz</Heading>
    <p class="lede">
      I&apos;m a software developer living in Sch&#246;ppingen, Germany. I care
      a lot about developer experience, cloud-native systems, and software that
      feels considered from the inside out.
    </p>
  </section>

  <section class="about-overview">
    <div class="about-copy">
      <p>
        My day-to-day work is usually somewhere between backend engineering,
        internal tooling, and the small details that make developers happier to
        work with a system.
      </p>
      <p>
        Outside of work I like games, both digital and analog, learning new
        technologies like Rust, Go, Elixir, Kubernetes, and Pulumi, and spending
        time bouldering.
      </p>
    </div>

    <div class="portrait-frame">
      <Image
        src={portraitImage}
        alt="Steffen Beisenherz"
        class="about-portrait"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <section class="section-card">
    <p class="eyebrow">Career timeline</p>
    <h2 class="section-title">
      Roles across developer tooling, backend products, and e-commerce
      platforms.
    </h2>

    <div class="timeline">
      {jobs.map((job) => <Job {...job} />)}
    </div>
  </section>
</Layout>
