---
import { Image } from "astro:assets";
import { default as Layout } from "../layouts/BaseLayout.astro";
import Heading from "../components/heading.astro";
import armadilloImage from "../assets/armadillo-sorry.png";
---

<Layout title="404">
  <section class="not-found-card">
    <div class="about-copy">
      <p class="eyebrow">404</p>
      <Heading>Page not found</Heading>
      <p class="lede">
        The page you were looking for does not exist, moved elsewhere, or was
        never published.
      </p>
      <a href="/" class="inline-action">Return to the homepage</a>
    </div>

    <Image
      src={armadilloImage}
      alt="Armadillo being sorry"
      class="not-found-image"
    />
  </section>
</Layout>
