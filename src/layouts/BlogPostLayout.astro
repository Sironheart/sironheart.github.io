---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  image?: string;
}

const { title, description, publishedAt, image } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title}>
  <article class="article-shell">
    <a href="/blog" class="back-link">Back to blog</a>

    <header class="article-header">
      <p class="eyebrow">Blog</p>
      <h1 class="article-title">{title}</h1>
      <p class="article-lede">{description}</p>
      <p class="article-meta">Published {formattedDate}</p>
    </header>

    {
      image && (
        <div class="article-image-frame">
          <img src={image} alt={title} class="article-image" />
        </div>
      )
    }

    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>
